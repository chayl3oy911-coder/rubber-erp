// Rubber ERP — Prisma schema
// ───────────────────────────────────────────────────────────────────────────
// Conventions (Phase 0 · Step 2 · Database Foundation):
//   - id           : uuid via gen_random_uuid(), native Postgres @db.Uuid
//   - createdAt    : @default(now()) on every model
//   - updatedAt    : @updatedAt on every model EXCEPT AuditLog (immutable)
//   - Soft delete  : isActive Boolean — never hard delete from app layer
//   - Branch scope : branchId on every business row tied to a สาขา
//   - Supabase Auth: AppUser.supabaseUserId === auth.users.id (logical link,
//                    not an FK because auth lives in a different schema)
//
// Out of scope here: Purchase / Stock / Production / Sales / Cash modules,
// runtime auth/RBAC enforcement, RLS. Those land in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Identity ────────────────────────────────────────────────────────────────

model AppUser {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supabaseUserId String   @unique @db.Uuid
  email          String   @unique
  displayName    String
  phone          String?
  isSuperAdmin   Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userRoles    UserRole[]
  userBranches UserBranch[]
  auditLogs    AuditLog[]   @relation("AuditActor")

  purchaseTicketsCreated   PurchaseTicket[] @relation("PurchaseCreator")
  purchaseTicketsApproved  PurchaseTicket[] @relation("PurchaseApprover")
  purchaseTicketsCancelled PurchaseTicket[] @relation("PurchaseCanceller")

  stockLotsCreated      StockLot[]      @relation("StockLotCreator")
  stockMovementsCreated StockMovement[] @relation("StockMovementCreator")

  salesOrdersCreated   SalesOrder[] @relation("SalesCreator")
  salesOrdersConfirmed SalesOrder[] @relation("SalesConfirmer")
  salesOrdersCancelled SalesOrder[] @relation("SalesCanceller")
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  name        String
  description String?
  module      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model UserRole {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @db.Uuid
  roleId       String   @db.Uuid
  assignedById String?  @db.Uuid
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ─── Branch & Branch Access ──────────────────────────────────────────────────

model Branch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userBranches    UserBranch[]
  customers       Customer[]
  purchaseTickets PurchaseTicket[]
  stockLots       StockLot[]
  stockMovements  StockMovement[]
  salesOrders     SalesOrder[]
  auditLogs       AuditLog[]
}

model UserBranch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  branchId  String   @db.Uuid
  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

// ─── Master Data ─────────────────────────────────────────────────────────────

// ─── Customer ────────────────────────────────────────────────────────────────
//
// Trading partners we *buy raw rubber from* (formerly "Farmer"). The new name
// reflects business reality: counterparts include farmers, dealers, middlemen,
// and cooperatives. Bank accounts moved to a dedicated table because a single
// customer may now have up to 3 of them.

model Customer {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String   @db.Uuid
  code       String
  fullName   String
  phone      String?
  nationalId String?
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branch          Branch                @relation(fields: [branchId], references: [id])
  bankAccounts    CustomerBankAccount[]
  purchaseTickets PurchaseTicket[]

  @@unique([branchId, code])
  @@index([branchId])
}

// 1 customer ≤ 3 active bank accounts (enforced in service layer + transaction).
// Exactly one row may have isPrimary=true per customer (also service-enforced
// because Postgres partial unique indexes aren't expressible via Prisma's
// `@@unique`; we may add a raw-SQL CREATE UNIQUE INDEX later if scale demands).
//
// `@@unique([bankName, bankAccountNo])` is GLOBAL and prevents accidental
// duplicate-customer creation when the same person is re-entered: the second
// insert collides on this unique key (caught as P2002) and we surface a
// "duplicate bank account" error pointing the operator at the existing
// customer.
model CustomerBankAccount {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId    String   @db.Uuid
  bankName      String
  bankAccountNo String
  accountName   String?
  isPrimary     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([bankName, bankAccountNo])
  @@index([customerId])
}

// ─── Purchase ────────────────────────────────────────────────────────────────
//
// Receives raw rubber from farmers. ticketNo is auto-generated per-branch
// (PUR000001, PUR000002, …) inside a transaction with retry; uniqueness
// enforced by `@@unique([branchId, ticketNo])`.
//
// Money/weight columns use Decimal for exactness. netWeight and totalAmount
// are persisted (server-computed) so list queries and future Stock/Reports
// can sort/aggregate without recomputing — and so audit snapshots reflect
// the exact values at the time of write.
//
// Status transitions are strict-forward: DRAFT → WAITING_QC → WAITING_APPROVAL
// → APPROVED. CANCELLED is a terminal state reachable from any non-terminal
// state. APPROVED is locked against field edits per business rule.
//
// Document/PDF fields (company, logo, tax id) intentionally NOT here — those
// belong to a future Setting/Company table read at print time.

model PurchaseTicket {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String @db.Uuid
  customerId String @db.Uuid
  ticketNo   String

  rubberType String

  grossWeight Decimal @db.Decimal(12, 2)
  tareWeight  Decimal @default(0) @db.Decimal(12, 2)
  netWeight   Decimal @db.Decimal(12, 2)
  pricePerKg  Decimal @db.Decimal(12, 4)
  totalAmount Decimal @db.Decimal(14, 2)

  // ─── Withholding tax (เก็บลง DB ทุกใบเพื่อ trace ภาษีย้อนหลังได้) ──────────
  // pricePerKg ยังคง 4 ตำแหน่งเพราะตลาดยางจริงใช้ทศนิยม 4 ตำแหน่ง.
  // weight/total/tax/netPayable ใช้ 2 ตำแหน่งทั้งหมด.
  // service จะ recompute และเขียนทับเสมอ — `@default(0)` มีไว้กัน migration
  // แตกถ้ามี row เก่าโผล่มา (ไม่ควรเกิดในรอบนี้เพราะตารางว่าง).
  withholdingTaxPercent Decimal @default(0) @db.Decimal(5, 2)
  withholdingTaxAmount  Decimal @default(0) @db.Decimal(14, 2)
  netPayableAmount      Decimal @default(0) @db.Decimal(14, 2)

  status String
  note   String?

  approvedAt    DateTime?
  approvedById  String?   @db.Uuid
  cancelledAt   DateTime?
  cancelledById String?   @db.Uuid
  cancelReason  String?

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String   @db.Uuid

  branch      Branch   @relation(fields: [branchId], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])
  createdBy   AppUser  @relation("PurchaseCreator", fields: [createdById], references: [id])
  approvedBy  AppUser? @relation("PurchaseApprover", fields: [approvedById], references: [id])
  cancelledBy AppUser? @relation("PurchaseCanceller", fields: [cancelledById], references: [id])

  // 1 ticket → 1 lot. Reverse side; the unique constraint lives on `StockLot`.
  stockLot StockLot?

  @@unique([branchId, ticketNo])
  @@index([branchId, status])
  @@index([branchId, createdAt])
  @@index([customerId])
}

// ─── Stock ───────────────────────────────────────────────────────────────────
//
// Lot-based stock — one APPROVED PurchaseTicket creates exactly one StockLot
// (enforced both in the service layer and by `@@unique([sourcePurchaseTicketId])`).
// Aggregate stock is forbidden: every weight change MUST flow through a
// StockMovement row, never via a direct UPDATE on `remainingWeight`.
//
// Cost rules:
// - `costAmount` = PurchaseTicket.totalAmount at the time of inbound (cost
//   of goods received). Withholding tax / net payable are payment-layer
//   concerns and intentionally not used as stock cost.
// - `effectiveCostPerKg` = costAmount / remainingWeight, recomputed on every
//   weight change. Adjustments (e.g. WATER_LOSS) keep `costAmount` constant
//   but raise `effectiveCostPerKg` proportionally — modelling sunk cost on
//   weight loss exactly as accountants expect.
// - When `remainingWeight` reaches 0 the lot becomes `DEPLETED` and the
//   `effectiveCostPerKg` is FROZEN at its last value (no division by zero,
//   and the final cost rate stays auditable forever).
//
// Status string-coded ("ACTIVE" | "DEPLETED" | "CANCELLED") to match the
// PurchaseTicket convention; we'll only reach for a Postgres enum when the
// value-set genuinely stabilises.
//
// Movement types are append-only history (PURCHASE_IN / ADJUST_IN /
// ADJUST_OUT in this step; SALES_OUT / PRODUCTION_* / CANCEL_REVERSE land in
// later phases). `quantity` is always absolute (≥ 0) — the type carries the
// direction. `beforeWeight` / `afterWeight` are the lot's `remainingWeight`
// snapshots before/after this movement so reports can replay history without
// joining back to the lot.

model StockLot {
  id                     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId               String @db.Uuid
  sourcePurchaseTicketId String @db.Uuid
  lotNo                  String

  rubberType String

  // Weights — 2 dp matches PurchaseTicket.netWeight precisely.
  initialWeight   Decimal @db.Decimal(12, 2)
  remainingWeight Decimal @db.Decimal(12, 2)

  // Cost — 2 dp on totals (Thai retail/tax norm); 4 dp on rate to absorb
  // recompute drift from adjustments without losing precision.
  costAmount         Decimal @db.Decimal(14, 2)
  effectiveCostPerKg Decimal @db.Decimal(14, 4)

  status      String // ACTIVE | DEPLETED | CANCELLED
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String   @db.Uuid

  branch               Branch         @relation(fields: [branchId], references: [id])
  sourcePurchaseTicket PurchaseTicket @relation(fields: [sourcePurchaseTicketId], references: [id])
  createdBy            AppUser        @relation("StockLotCreator", fields: [createdById], references: [id])

  movements   StockMovement[]
  salesOrders SalesOrder[]

  @@unique([branchId, lotNo])
  // Hard guarantee that one PurchaseTicket cannot produce two lots, even on
  // concurrent requests. Service catches P2002 and surfaces 409.
  @@unique([sourcePurchaseTicketId])
  @@index([branchId])
  @@index([branchId, status])
  @@index([branchId, rubberType])
  @@index([branchId, createdAt])
}

model StockMovement {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String @db.Uuid
  stockLotId String @db.Uuid

  movementType String // PURCHASE_IN | ADJUST_IN | ADJUST_OUT | SALES_OUT | PRODUCTION_OUT | PRODUCTION_IN | CANCEL_REVERSE
  quantity     Decimal @db.Decimal(12, 2)

  beforeWeight Decimal @db.Decimal(12, 2)
  afterWeight  Decimal @db.Decimal(12, 2)

  // For ADJUST_*: required (validated in service).
  // For PURCHASE_IN / SALES_OUT / etc.: null.
  reasonType String? // WATER_LOSS | DAMAGE | SCALE_ERROR | MANUAL_CORRECTION | OTHER

  // Polymorphic reference back to whatever drove this movement (e.g.
  // PurchaseTicket / Sale / ProductionOrder). Both fields are null for
  // manual ADJUST_* — those are uniquely identified by `id` + lot history.
  referenceType String?
  referenceId   String? @db.Uuid

  note String?

  createdAt   DateTime @default(now())
  createdById String   @db.Uuid

  branch    Branch   @relation(fields: [branchId], references: [id])
  stockLot  StockLot @relation(fields: [stockLotId], references: [id])
  createdBy AppUser  @relation("StockMovementCreator", fields: [createdById], references: [id])

  @@index([stockLotId, createdAt])
  @@index([branchId, movementType])
  @@index([referenceType, referenceId])
}

// ─── Sales (Factory sales + DRC) ─────────────────────────────────────────────
//
// One SalesOrder targets exactly one StockLot. Multiple sales can be created
// from the same lot until its `remainingWeight` runs out. The wet weight
// (`grossWeight`) is what actually leaves the lot via a SALES_OUT movement;
// the dry weight (`drcWeight = grossWeight × drcPercent / 100`) is purely
// a sale/revenue concept and NEVER touches stock.
//
// Cost / profit are snapshotted on this row at create-time (preview) AND
// re-snapshotted at confirm (lot cost may have shifted via adjustments
// between draft & confirm). Once CONFIRMED these are immutable historical
// records — adjustments to the lot AFTER confirm do not retro-modify sales.
//
// Withholding tax / netReceivable / receivedAt / expectedReceiveDate are
// reserved for the future Payment + Reconciliation module. Step 9 only
// computes & stores them; no Payment row is created.
//
// Status string-coded ("DRAFT" | "CONFIRMED" | "CANCELLED") matching the
// PurchaseTicket / StockLot convention. RECEIVED is reserved for the
// future payment step.

model SalesOrder {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String @db.Uuid
  stockLotId String @db.Uuid
  salesNo    String

  // Buyer (factory). Snapshot at sale time even after a future
  // BuyerFactory master is introduced, so historical rows survive renames.
  buyerName  String
  saleType   String // SALE | CONSIGNMENT
  rubberType String // snapshot from StockLot at create-time

  // ── Weights ──
  // grossWeight = wet weight that actually leaves the lot (drives stock).
  // drcWeight   = dry rubber content used for pricing (NEVER drives stock).
  grossWeight Decimal @db.Decimal(12, 2)
  drcPercent  Decimal @db.Decimal(5, 2)
  drcWeight   Decimal @db.Decimal(12, 2)

  // ── Sale price ──
  pricePerKg  Decimal @db.Decimal(14, 4)
  grossAmount Decimal @db.Decimal(14, 2) // = drcWeight × pricePerKg

  // ── Withholding tax ──
  withholdingTaxPercent Decimal @default(0) @db.Decimal(5, 2)
  withholdingTaxAmount  Decimal @default(0) @db.Decimal(14, 2)
  netReceivableAmount   Decimal @db.Decimal(14, 2) // = grossAmount − withholdingTaxAmount

  // ── Cost / profit snapshot ──
  // costAmount  = grossWeight × StockLot.effectiveCostPerKg (at confirm time)
  // profitAmount = grossAmount − costAmount
  costAmount   Decimal @default(0) @db.Decimal(14, 2)
  profitAmount Decimal @default(0) @db.Decimal(14, 2)

  // ── Status / lifecycle ──
  status              String // DRAFT | CONFIRMED | CANCELLED
  expectedReceiveDate DateTime?
  receivedAt          DateTime?
  note                String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById   String    @db.Uuid
  confirmedAt   DateTime?
  confirmedById String?   @db.Uuid
  cancelledAt   DateTime?
  cancelledById String?   @db.Uuid
  cancelReason  String?

  branch      Branch   @relation(fields: [branchId], references: [id])
  stockLot    StockLot @relation(fields: [stockLotId], references: [id])
  createdBy   AppUser  @relation("SalesCreator", fields: [createdById], references: [id])
  confirmedBy AppUser? @relation("SalesConfirmer", fields: [confirmedById], references: [id])
  cancelledBy AppUser? @relation("SalesCanceller", fields: [cancelledById], references: [id])

  @@unique([branchId, salesNo])
  @@index([branchId])
  @@index([branchId, status])
  @@index([branchId, saleType])
  @@index([branchId, createdAt])
  @@index([stockLotId])
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String   @db.Uuid
  branchId   String?  @db.Uuid
  entityType String
  entityId   String   @db.Uuid
  action     String
  before     Json?
  after      Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor  AppUser @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([branchId, createdAt])
}

// Rubber ERP — Prisma schema
// ───────────────────────────────────────────────────────────────────────────
// Conventions (Phase 0 · Step 2 · Database Foundation):
//   - id           : uuid via gen_random_uuid(), native Postgres @db.Uuid
//   - createdAt    : @default(now()) on every model
//   - updatedAt    : @updatedAt on every model EXCEPT AuditLog (immutable)
//   - Soft delete  : isActive Boolean — never hard delete from app layer
//   - Branch scope : branchId on every business row tied to a สาขา
//   - Supabase Auth: AppUser.supabaseUserId === auth.users.id (logical link,
//                    not an FK because auth lives in a different schema)
//
// Out of scope here: Purchase / Stock / Production / Sales / Cash modules,
// runtime auth/RBAC enforcement, RLS. Those land in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Identity ────────────────────────────────────────────────────────────────

model AppUser {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supabaseUserId String   @unique @db.Uuid
  email          String   @unique
  displayName    String
  phone          String?
  isSuperAdmin   Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userRoles    UserRole[]
  userBranches UserBranch[]
  auditLogs    AuditLog[]   @relation("AuditActor")

  purchaseTicketsCreated         PurchaseTicket[] @relation("PurchaseCreator")
  purchaseTicketsApproved        PurchaseTicket[] @relation("PurchaseApprover")
  purchaseTicketsCancelled       PurchaseTicket[] @relation("PurchaseCanceller")
  purchaseTicketsStockIntakeSkip PurchaseTicket[] @relation("PurchaseStockIntakeSkipper")

  stockLotsCreated      StockLot[]      @relation("StockLotCreator")
  stockMovementsCreated StockMovement[] @relation("StockMovementCreator")

  salesOrdersCreated   SalesOrder[] @relation("SalesCreator")
  salesOrdersConfirmed SalesOrder[] @relation("SalesConfirmer")
  salesOrdersCancelled SalesOrder[] @relation("SalesCanceller")

  receivingEntitiesCreated ReceivingEntity[] @relation("ReceivingEntityCreator")

  purchaseReturnsCreated   PurchaseReturn[] @relation("PurchaseReturnCreator")
  purchaseReturnsConfirmed PurchaseReturn[] @relation("PurchaseReturnConfirmer")
  purchaseReturnsCancelled PurchaseReturn[] @relation("PurchaseReturnCanceller")
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  name        String
  description String?
  module      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model UserRole {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @db.Uuid
  roleId       String   @db.Uuid
  assignedById String?  @db.Uuid
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ─── Branch & Branch Access ──────────────────────────────────────────────────

model Branch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userBranches      UserBranch[]
  customers         Customer[]
  purchaseTickets   PurchaseTicket[]
  stockLots         StockLot[]
  stockMovements    StockMovement[]
  salesOrders       SalesOrder[]
  receivingEntities ReceivingEntity[]
  purchaseReturns   PurchaseReturn[]
  auditLogs         AuditLog[]
}

model UserBranch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  branchId  String   @db.Uuid
  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

// ─── Master Data ─────────────────────────────────────────────────────────────

// ─── Customer ────────────────────────────────────────────────────────────────
//
// Trading partners we *buy raw rubber from* (formerly "Farmer"). The new name
// reflects business reality: counterparts include farmers, dealers, middlemen,
// and cooperatives. Bank accounts moved to a dedicated table because a single
// customer may now have up to 3 of them.

model Customer {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String   @db.Uuid
  code       String
  fullName   String
  phone      String?
  nationalId String?
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branch          Branch                @relation(fields: [branchId], references: [id])
  bankAccounts    CustomerBankAccount[]
  purchaseTickets PurchaseTicket[]

  @@unique([branchId, code])
  @@index([branchId])
}

// 1 customer ≤ 3 active bank accounts (enforced in service layer + transaction).
// Exactly one row may have isPrimary=true per customer (also service-enforced
// because Postgres partial unique indexes aren't expressible via Prisma's
// `@@unique`; we may add a raw-SQL CREATE UNIQUE INDEX later if scale demands).
//
// `@@unique([bankName, bankAccountNo])` is GLOBAL and prevents accidental
// duplicate-customer creation when the same person is re-entered: the second
// insert collides on this unique key (caught as P2002) and we surface a
// "duplicate bank account" error pointing the operator at the existing
// customer.
model CustomerBankAccount {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId    String   @db.Uuid
  bankName      String
  bankAccountNo String
  accountName   String?
  isPrimary     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([bankName, bankAccountNo])
  @@index([customerId])
}

// ─── Purchase ────────────────────────────────────────────────────────────────
//
// Receives raw rubber from farmers. ticketNo is auto-generated per-branch
// (PUR000001, PUR000002, …) inside a transaction with retry; uniqueness
// enforced by `@@unique([branchId, ticketNo])`.
//
// Money/weight columns use Decimal for exactness. netWeight and totalAmount
// are persisted (server-computed) so list queries and future Stock/Reports
// can sort/aggregate without recomputing — and so audit snapshots reflect
// the exact values at the time of write.
//
// Status transitions are strict-forward: DRAFT → WAITING_QC → WAITING_APPROVAL
// → APPROVED. CANCELLED is a terminal state reachable from any non-terminal
// state. APPROVED is locked against field edits per business rule.
//
// Document/PDF fields (company, logo, tax id) intentionally NOT here — those
// belong to a future Setting/Company table read at print time.

model PurchaseTicket {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String @db.Uuid
  customerId String @db.Uuid
  ticketNo   String

  rubberType String

  grossWeight Decimal @db.Decimal(12, 2)
  tareWeight  Decimal @default(0) @db.Decimal(12, 2)
  netWeight   Decimal @db.Decimal(12, 2)
  pricePerKg  Decimal @db.Decimal(12, 2)
  totalAmount Decimal @db.Decimal(14, 2)

  // ─── Withholding tax (เก็บลง DB ทุกใบเพื่อ trace ภาษีย้อนหลังได้) ──────────
  // ระบบนี้กำหนดราคา/กก. และต้นทุน/กก. เป็น 2 ตำแหน่งทั้งระบบ เพื่อให้ตรงกับ
  // การทำงานจริงและการแสดงผล (money/weight/percent ทั้งหมดใช้ 2 dp HALF_UP).
  // service จะ recompute และเขียนทับเสมอ — `@default(0)` มีไว้กัน migration
  // แตกถ้ามี row เก่าโผล่มา (ไม่ควรเกิดในรอบนี้เพราะตารางว่าง).
  withholdingTaxPercent Decimal @default(0) @db.Decimal(5, 2)
  withholdingTaxAmount  Decimal @default(0) @db.Decimal(14, 2)
  netPayableAmount      Decimal @default(0) @db.Decimal(14, 2)

  status String
  note   String?

  approvedAt    DateTime?
  approvedById  String?   @db.Uuid
  cancelledAt   DateTime?
  cancelledById String?   @db.Uuid
  cancelReason  String?

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String   @db.Uuid

  // ─── Stock intake (Step 11) ────────────────────────────────────────────────
  // `stockIntakeStatus` is a separate axis from `status` (the purchase
  // lifecycle): an APPROVED ticket is still PENDING intake until either a
  // lot is created (RECEIVED) or the operator explicitly chooses not to
  // ingest (SKIPPED). Decoupling these two axes lets us cleanly model the
  // real-world cases: "approved but never delivered", "approved, delivered,
  // not yet logged", "delivered and logged", and "approved + skipped".
  // Filling these columns is service's job — never touch them directly.
  stockIntakeStatus      String    @default("PENDING")
  // "PENDING" | "RECEIVED" | "SKIPPED"
  stockIntakeReceivedAt  DateTime?
  stockIntakeSkippedAt   DateTime?
  stockIntakeSkippedById String?   @db.Uuid
  stockIntakeSkipReason  String?

  // ─── Payment status (Step 11 — column-only forward-compat) ─────────────────
  // No business logic reads/writes this in this step; it exists so that a
  // future Payment feature can backfill values without an ALTER TABLE on a
  // hot table. Keep DEFAULT 'UNPAID' so all existing rows stay consistent.
  paymentStatus String @default("UNPAID")
  // "UNPAID" | "PARTIAL" | "PAID"

  branch      Branch   @relation(fields: [branchId], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])
  createdBy   AppUser  @relation("PurchaseCreator", fields: [createdById], references: [id])
  approvedBy  AppUser? @relation("PurchaseApprover", fields: [approvedById], references: [id])
  cancelledBy AppUser? @relation("PurchaseCanceller", fields: [cancelledById], references: [id])

  stockIntakeSkippedBy AppUser? @relation("PurchaseStockIntakeSkipper", fields: [stockIntakeSkippedById], references: [id])

  // 1 ticket → 1 lot. Reverse side; the unique constraint lives on `StockLot`.
  stockLot StockLot?

  // 1 ticket → 0..N returns (DRAFT/CONFIRMED/CANCELLED).
  purchaseReturns PurchaseReturn[]

  @@unique([branchId, ticketNo])
  @@index([branchId, status])
  @@index([branchId, createdAt])
  @@index([customerId])
  @@index([branchId, stockIntakeStatus])
  @@index([branchId, paymentStatus])
}

// ─── Stock ───────────────────────────────────────────────────────────────────
//
// Lot-based stock — one APPROVED PurchaseTicket creates exactly one StockLot
// (enforced both in the service layer and by `@@unique([sourcePurchaseTicketId])`).
// Aggregate stock is forbidden: every weight change MUST flow through a
// StockMovement row, never via a direct UPDATE on `remainingWeight`.
//
// Cost rules:
// - `costAmount` = PurchaseTicket.totalAmount at the time of inbound (cost
//   of goods received). Withholding tax / net payable are payment-layer
//   concerns and intentionally not used as stock cost.
// - `effectiveCostPerKg` = costAmount / remainingWeight, recomputed on every
//   weight change. Adjustments (e.g. WATER_LOSS) keep `costAmount` constant
//   but raise `effectiveCostPerKg` proportionally — modelling sunk cost on
//   weight loss exactly as accountants expect.
// - When `remainingWeight` reaches 0 the lot becomes `DEPLETED` and the
//   `effectiveCostPerKg` is FROZEN at its last value (no division by zero,
//   and the final cost rate stays auditable forever).
//
// Status string-coded ("ACTIVE" | "DEPLETED" | "CANCELLED") to match the
// PurchaseTicket convention; we'll only reach for a Postgres enum when the
// value-set genuinely stabilises.
//
// Movement types are append-only history (PURCHASE_IN / ADJUST_IN /
// ADJUST_OUT in this step; SALES_OUT / PRODUCTION_* / CANCEL_REVERSE land in
// later phases). `quantity` is always absolute (≥ 0) — the type carries the
// direction. `beforeWeight` / `afterWeight` are the lot's `remainingWeight`
// snapshots before/after this movement so reports can replay history without
// joining back to the lot.

model StockLot {
  id                     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId               String @db.Uuid
  sourcePurchaseTicketId String @db.Uuid
  lotNo                  String

  rubberType String

  // Weights — 2 dp matches PurchaseTicket.netWeight precisely.
  initialWeight   Decimal @db.Decimal(12, 2)
  remainingWeight Decimal @db.Decimal(12, 2)

  // Cost — 2 dp on totals (Thai retail/tax norm); 4 dp on rate to absorb
  // recompute drift from adjustments without losing precision.
  costAmount         Decimal @db.Decimal(14, 2)
  // ต้นทุน/กก. ใช้ 2 ตำแหน่งทั้งระบบ (รอบ HALF_UP ใน service).
  effectiveCostPerKg Decimal @db.Decimal(14, 2)

  status      String // ACTIVE | DEPLETED | CANCELLED
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String   @db.Uuid

  branch               Branch         @relation(fields: [branchId], references: [id])
  sourcePurchaseTicket PurchaseTicket @relation(fields: [sourcePurchaseTicketId], references: [id])
  createdBy            AppUser        @relation("StockLotCreator", fields: [createdById], references: [id])

  movements       StockMovement[]
  salesOrderLines SalesOrderLine[]
  purchaseReturns PurchaseReturn[]

  @@unique([branchId, lotNo])
  // Hard guarantee that one PurchaseTicket cannot produce two lots, even on
  // concurrent requests. Service catches P2002 and surfaces 409.
  @@unique([sourcePurchaseTicketId])
  @@index([branchId])
  @@index([branchId, status])
  @@index([branchId, rubberType])
  @@index([branchId, createdAt])
}

model StockMovement {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String @db.Uuid
  stockLotId String @db.Uuid

  movementType String // PURCHASE_IN | ADJUST_IN | ADJUST_OUT | SALES_OUT | PRODUCTION_OUT | PRODUCTION_IN | CANCEL_REVERSE
  quantity     Decimal @db.Decimal(12, 2)

  beforeWeight Decimal @db.Decimal(12, 2)
  afterWeight  Decimal @db.Decimal(12, 2)

  // For ADJUST_*: required (validated in service).
  // For PURCHASE_IN / SALES_OUT / etc.: null.
  reasonType String? // WATER_LOSS | DAMAGE | SCALE_ERROR | MANUAL_CORRECTION | OTHER

  // Polymorphic reference back to whatever drove this movement (e.g.
  // PurchaseTicket / Sale / ProductionOrder). Both fields are null for
  // manual ADJUST_* — those are uniquely identified by `id` + lot history.
  referenceType String?
  referenceId   String? @db.Uuid

  note String?

  createdAt   DateTime @default(now())
  createdById String   @db.Uuid

  branch    Branch   @relation(fields: [branchId], references: [id])
  stockLot  StockLot @relation(fields: [stockLotId], references: [id])
  createdBy AppUser  @relation("StockMovementCreator", fields: [createdById], references: [id])

  // 1:1 inverse — a SALES_OUT movement is referenced by exactly one
  // SalesOrderLine (CANCEL_REVERSE movements are NOT linked back via
  // SalesOrderLine.movementId, so they leave this null).
  salesOrderLine SalesOrderLine? @relation("SalesOrderLineMovement")

  // 1:1 inverse — a PURCHASE_RETURN_OUT movement belongs to exactly one
  // CONFIRMED PurchaseReturn. DRAFT / CANCELLED returns leave this null.
  purchaseReturn PurchaseReturn? @relation("PurchaseReturnMovement")

  @@index([stockLotId, createdAt])
  @@index([branchId, movementType])
  @@index([referenceType, referenceId])
}

// ─── Purchase Return (Step 12) ──────────────────────────────────────────────
//
// Reverse-flow for the case where a purchase has already been received into
// stock but the goods turn out to have a problem (QC error, supplier
// returns, wrong entry, etc.). We record an explicit `PurchaseReturn`
// document instead of mutating the original purchase / stock lot in place,
// because:
//
//   1. The `PurchaseTicket` and `StockLot` rows are immutable after intake
//      by design (audit-quality history). Returning is a *new* event, not
//      an edit to the past.
//   2. Returns can be partial (return 200 of 1000 kg) and there can be many
//      against a single lot over time — a separate row per return is the
//      cleanest way to model this without abusing adjustment notes.
//   3. The Payment / Refund feature (a future step) needs a stable id to
//      reference the returned amount.
//
// Workflow:
//
//   DRAFT  ─ confirm ─▶ CONFIRMED   (creates a PURCHASE_RETURN_OUT movement,
//     │                              shrinks lot.remainingWeight + costAmount,
//     │                              recomputes effectiveCostPerKg)
//     │
//     └── cancel ───▶ CANCELLED      (no stock side-effect; reason recorded)
//
// CONFIRMED is FINAL — there is no "un-confirm". Mistakes are corrected by
// an opposite ADJUST_IN (with reason) or a future counter-flow; this keeps
// the audit chain monotonic.
//
// Cost semantics (parallel to SALES_OUT, NOT to ADJUST_OUT):
//   returnCostAmount      = effectiveCostPerKg × returnWeight  (HALF_UP, 2dp)
//   lot.costAmount       -= returnCostAmount  (clamped ≥ 0)
//   lot.remainingWeight  -= returnWeight
//   lot.effectiveCostPerKg = lot.costAmount / lot.remainingWeight, OR
//                            FROZEN at its previous value when remainingWeight
//                            reaches 0 (so the historical rate is preserved).

model PurchaseReturn {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId         String @db.Uuid
  purchaseTicketId String @db.Uuid
  stockLotId       String @db.Uuid

  returnNo String // e.g. "PRT000001" — branch-scoped, auto-generated
  status   String @default("DRAFT") // DRAFT | CONFIRMED | CANCELLED

  // Reason is required; "OTHER" requires a non-empty `returnReasonNote`
  // (validated in the service layer — DB stays permissive).
  returnReasonType String // PRODUCT_ISSUE | QC_ERROR | WRONG_ENTRY | SUPPLIER_RETURN | OTHER
  returnReasonNote String?

  // Quantity & cost
  returnWeight     Decimal @db.Decimal(12, 2)
  // Computed at confirm time from the FRESH lot.effectiveCostPerKg under
  // FOR UPDATE. While DRAFT this column holds a preview value (UI label
  // makes that clear); confirm overwrites it with the authoritative number
  // before flipping status to CONFIRMED.
  returnCostAmount Decimal @default(0) @db.Decimal(14, 2)

  // Snapshots — frozen at create-time so the return record is readable
  // even if the supplier or lot is later renamed/deactivated.
  customerCodeSnapshot String?
  customerNameSnapshot String?
  ticketNoSnapshot     String?
  lotNoSnapshot        String?

  // 1:1 link to the StockMovement created at confirm. Null while DRAFT
  // and CANCELLED (cancelled drafts never produced a movement).
  stockMovementId String? @unique @db.Uuid

  // Forward-compat for Payment/Refund — no logic in this step. The default
  // is PENDING; on confirm the service flips it to NOT_REQUIRED when the
  // ticket's paymentStatus is UNPAID (no money has changed hands yet).
  refundStatus   String  @default("PENDING") // PENDING | NOT_REQUIRED | REFUNDED | CREDITED
  refundedAmount Decimal @default(0) @db.Decimal(14, 2)

  // Workflow
  createdById   String    @db.Uuid
  createdAt     DateTime  @default(now())
  confirmedById String?   @db.Uuid
  confirmedAt   DateTime?
  cancelledById String?   @db.Uuid
  cancelledAt   DateTime?
  cancelReason  String?

  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  branch         Branch         @relation(fields: [branchId], references: [id])
  purchaseTicket PurchaseTicket @relation(fields: [purchaseTicketId], references: [id])
  stockLot       StockLot       @relation(fields: [stockLotId], references: [id])
  stockMovement  StockMovement? @relation("PurchaseReturnMovement", fields: [stockMovementId], references: [id])

  createdBy   AppUser  @relation("PurchaseReturnCreator", fields: [createdById], references: [id])
  confirmedBy AppUser? @relation("PurchaseReturnConfirmer", fields: [confirmedById], references: [id])
  cancelledBy AppUser? @relation("PurchaseReturnCanceller", fields: [cancelledById], references: [id])

  @@unique([branchId, returnNo])
  @@index([branchId, status])
  @@index([purchaseTicketId])
  @@index([stockLotId])
  @@index([branchId, createdAt])
}

// ─── Sales (Factory sales + DRC, multi-lot) ─────────────────────────────────
//
// 1 SalesOrder = หัวบิลขาย, 1..N SalesOrderLine = รายการ lot ที่ขาย.
// แต่ละ line ผูกกับ 1 StockLot และมี grossWeight ของตัวเอง — line คือ
// หน่วยที่ใช้ตัด stock จริง. Header (SalesOrder) ทำหน้าที่เก็บ DRC%, ราคา/กก.,
// ภาษี, และผลรวม (grossWeightTotal, drcWeightTotal, costAmount, profit).
//
// กฎสำคัญ:
//  - DRAFT: ยังไม่ตัด stock (สร้าง / แก้ / ลบ line ได้)
//  - CONFIRMED: lock lines (ห้ามแก้). Confirm จะ:
//      • SELECT FOR UPDATE ทุก StockLot ของแต่ละ line (เรียงตาม id ป้องกัน deadlock)
//      • re-validate grossWeight ≤ remainingWeight
//      • re-snapshot costPerKgSnapshot จาก lot.effectiveCostPerKg ปัจจุบัน
//      • สร้าง SALES_OUT movement 1 ตัวต่อ 1 line, ลด lot.remainingWeight
//      • ตั้ง lot.status = DEPLETED ถ้า remaining ถึง 0
//  - CANCELLED:
//      • from DRAFT → ไม่กระทบ stock
//      • from CONFIRMED → สร้าง CANCEL_REVERSE 1 ตัวต่อ 1 line คืน weight กลับ
//
// DRC% ใช้คิด revenue เท่านั้น — ไม่กระทบ stock. Stock ตัดด้วย line.grossWeight.

model SalesOrder {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId String @db.Uuid
  salesNo  String

  // Buyer (factory). Snapshot at sale time even after a future
  // BuyerFactory master is introduced, so historical rows survive renames.
  buyerName String
  saleType  String // SALE | CONSIGNMENT

  // ── Aggregates (recomputed every create / line-replace / confirm) ──
  // grossWeightTotal = Σ line.grossWeight  → drives stock cuts at confirm.
  // drcWeightTotal   = grossWeightTotal × drcPercent / 100  → revenue only.
  grossWeightTotal Decimal @db.Decimal(12, 2)
  drcPercent       Decimal @db.Decimal(5, 2)
  drcWeightTotal   Decimal @db.Decimal(12, 2)

  // ── Sale price (header-level) ──
  // ราคา/กก. ใช้ 2 ตำแหน่งทั้งระบบ (รอบ HALF_UP ใน service).
  pricePerKg  Decimal @db.Decimal(14, 2)
  grossAmount Decimal @db.Decimal(14, 2) // = drcWeightTotal × pricePerKg

  // ── Withholding tax ──
  withholdingTaxPercent Decimal @default(0) @db.Decimal(5, 2)
  withholdingTaxAmount  Decimal @default(0) @db.Decimal(14, 2)
  netReceivableAmount   Decimal @db.Decimal(14, 2) // = grossAmount − withholdingTaxAmount

  // ── Cost / profit snapshot (Σ ของ line.costAmount) ──
  // costAmount   = Σ line.costAmount     (snapshot ใหม่ทุกครั้งที่ confirm)
  // profitAmount = grossAmount − costAmount
  costAmount   Decimal @default(0) @db.Decimal(14, 2)
  profitAmount Decimal @default(0) @db.Decimal(14, 2)

  // ── Status / lifecycle ──
  status              String // DRAFT | CONFIRMED | CANCELLED
  expectedReceiveDate DateTime?
  receivedAt          DateTime?
  note                String?

  // ── ขายในนาม / บัญชีรับเงิน (Receiving party) ──
  // FK + snapshot pattern: FK lets future Payment / Reconciliation join, while
  // the *Snapshot fields freeze the rendered values at create/edit time so the
  // historical document survives later master-data edits or deactivation.
  // Both FKs are nullable because pre-existing rows from before Step 10 had no
  // receiving info; new rows enforce non-null at the service layer (default
  // resolution → ReceivingDefaultMissingError if the workspace has no defaults).
  receivingEntityId      String? @db.Uuid
  receivingBankAccountId String? @db.Uuid

  receivingEntityNameSnapshot      String?
  receivingEntityTypeSnapshot      String? // COMPANY | PERSONAL
  receivingTaxIdSnapshot           String?
  receivingBankNameSnapshot        String?
  receivingBankAccountNoSnapshot   String?
  receivingBankAccountNameSnapshot String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById   String    @db.Uuid
  confirmedAt   DateTime?
  confirmedById String?   @db.Uuid
  cancelledAt   DateTime?
  cancelledById String?   @db.Uuid
  cancelReason  String?

  branch      Branch   @relation(fields: [branchId], references: [id])
  createdBy   AppUser  @relation("SalesCreator", fields: [createdById], references: [id])
  confirmedBy AppUser? @relation("SalesConfirmer", fields: [confirmedById], references: [id])
  cancelledBy AppUser? @relation("SalesCanceller", fields: [cancelledById], references: [id])

  receivingEntity      ReceivingEntity?      @relation("SalesReceivingEntity", fields: [receivingEntityId], references: [id])
  receivingBankAccount ReceivingBankAccount? @relation("SalesReceivingBankAccount", fields: [receivingBankAccountId], references: [id])

  lines SalesOrderLine[]

  @@unique([branchId, salesNo])
  @@index([branchId])
  @@index([branchId, status])
  @@index([branchId, saleType])
  @@index([branchId, createdAt])
  @@index([receivingEntityId])
  @@index([receivingBankAccountId])
}

// One row per StockLot referenced by a SalesOrder. Snapshots `rubberType`
// + `costPerKgSnapshot` so historical rows survive lot-level changes
// (rename, adjust). `costAmount` here is the line's contribution to the
// header total. `movementId` links 1:1 to the SALES_OUT movement created
// at confirm-time (null while DRAFT). CANCEL_REVERSE movements are NOT
// linked back here — they're discoverable via referenceType/referenceId.
model SalesOrderLine {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salesOrderId String @db.Uuid
  stockLotId   String @db.Uuid

  rubberType String // snapshot from StockLot at create-time

  grossWeight       Decimal @db.Decimal(12, 2)
  // ต้นทุน/กก. snapshot: 2 ตำแหน่งสอดคล้องกับ StockLot.effectiveCostPerKg.
  costPerKgSnapshot Decimal @db.Decimal(14, 2) // = lot.effectiveCostPerKg at create / confirm
  costAmount        Decimal @db.Decimal(14, 2) // = grossWeight × costPerKgSnapshot

  movementId String? @unique @db.Uuid // SALES_OUT movement created at confirm

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesOrder    SalesOrder     @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  stockLot      StockLot       @relation(fields: [stockLotId], references: [id])
  salesMovement StockMovement? @relation("SalesOrderLineMovement", fields: [movementId], references: [id])

  // 1 lot ปรากฏใน 1 บิลขายได้แค่ 1 ครั้ง — ห้าม duplicate. ถ้าจะขาย lot
  // เดิมรอบสอง ต้องเป็นบิลใหม่.
  @@unique([salesOrderId, stockLotId])
  @@index([salesOrderId])
  @@index([stockLotId])
}

// ─── Receiving / Company Payment Setup ──────────────────────────────────────
//
// "ขายในนาม" — the entity that appears on a SalesOrder as the legal receiver
// of the buyer's payment. Examples: บริษัท เอเวอร์รับเบอร์ จำกัด (COMPANY) or
// คุณสมชาย (PERSONAL) when the proprietor receives money personally for some
// channels. Master data only — Payment/Reconciliation lives in a future step.
//
// `branchId` semantics:
//   - NULL  = company-wide; visible/usable across every branch
//   - uuid  = scoped to that branch only; users not in that branch can't pick it
//
// `isDefault` semantics: at most ONE active default per scope, where a "scope"
// is one of {NULL, branchId-uuid}. Service-enforced inside a transaction via
// "clear-others-then-set". A Postgres partial unique index in the migration
// hardens this against races (Prisma can't express partial unique → raw SQL).
//
// FK from SalesOrder is `Restrict` (default Prisma behaviour for required
// relations? — here optional, so we still rely on `isActive=false` soft-
// delete; service forbids hard delete). Snapshot fields on SalesOrder mean a
// deactivated entity does NOT corrupt historical bills.
model ReceivingEntity {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId    String?  @db.Uuid
  type        String // COMPANY | PERSONAL
  name        String
  taxId       String?
  address     String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdById String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdBy AppUser? @relation("ReceivingEntityCreator", fields: [createdById], references: [id])

  bankAccounts ReceivingBankAccount[]
  salesOrders  SalesOrder[]           @relation("SalesReceivingEntity")

  @@index([branchId])
  @@index([isActive])
  @@index([isDefault])
  @@index([branchId, isActive])
}

// 1 ReceivingEntity ≤ 10 active bank accounts (service-enforced, mirrors the
// CustomerBankAccount pattern but raised from 3 → 10 because a company may
// hold accounts across multiple banks for collection-channel purposes).
//
// Uniqueness of (bankName, bankAccountNo) is SCOPED to the entity here (not
// global like CustomerBankAccount). Different entities — e.g. company vs.
// proprietor's personal — can legitimately share an account number.
//
// Exactly one active row may have `isPrimary = true` per entity. Enforced
// in service + a partial unique index from the migration (Prisma can't
// express `WHERE isPrimary AND isActive` partials).
//
// `bankAccountName` is REQUIRED here (versus CustomerBankAccount where it's
// optional) because this account is shown on the receipt the buyer pays into,
// and the account name must be printable.
model ReceivingBankAccount {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receivingEntityId String   @db.Uuid
  bankName          String
  bankAccountNo     String
  bankAccountName   String
  isPrimary         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  receivingEntity ReceivingEntity @relation(fields: [receivingEntityId], references: [id], onDelete: Cascade)
  salesOrders     SalesOrder[]    @relation("SalesReceivingBankAccount")

  @@unique([receivingEntityId, bankName, bankAccountNo])
  @@index([receivingEntityId])
  @@index([receivingEntityId, isActive])
  @@index([bankName, bankAccountNo])
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String   @db.Uuid
  branchId   String?  @db.Uuid
  entityType String
  entityId   String   @db.Uuid
  action     String
  before     Json?
  after      Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor  AppUser @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([branchId, createdAt])
}
